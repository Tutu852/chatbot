# Set the default line-ending style for text files
* text=auto

# Explicitly declare text files that should always have LF line endings
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Declare files that should always have binary encoding
*.png binary
*.jpg binary
*.ico binary
*.svg binary
